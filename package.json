{
  "name": "plaud-mirror",
  "version": "0.14.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:runtime && npm run build:web",
    "build:runtime": "tsc -b packages/shared/tsconfig.json apps/api/tsconfig.json",
    "build:web": "npm run build --workspace @plaud-mirror/web",
    "start": "npm run build && node apps/api/dist/cli/server.js",
    "test": "npm run build && npm run typecheck:web && npm run test:node && npm run test:web",
    "test:node": "node scripts/run-node-tests.mjs",
    "test:web": "npm run test --workspace @plaud-mirror/web",
    "typecheck:web": "tsc -p apps/web/tsconfig.json --noEmit",
    "contract:check": "node scripts/check-transcription-contract.mjs",
    "contract:conformance": "node scripts/check-transcription-provider.mjs",
    "spike": "npm run build:runtime && node apps/api/dist/cli/spike.js"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
