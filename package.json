{
  "name": "plaud-mirror",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/shared/tsconfig.json apps/api/tsconfig.json",
    "test": "npm run build && node --test packages/shared/dist/plaud.test.js apps/api/dist/plaud/client.test.js apps/api/dist/phase1/spike.test.js apps/api/dist/cli/spike.test.js",
    "spike": "npm run build && node apps/api/dist/cli/spike.js"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
