{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/cdelalama/plaud-mirror/main/docs/contracts/transcription-intake-status.v1.schema.json",
  "title": "Transcription Intake Status v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "intakeId", "source", "status", "occurredAt"],
  "properties": {
    "schemaVersion": { "const": "transcription.intake-status.v1" },
    "intakeId": { "type": "string", "minLength": 1, "maxLength": 200 },
    "source": { "$ref": "transcription-intake.v1.schema.json#/$defs/source" },
    "status": { "enum": ["accepted", "processing", "transcribed", "failed"] },
    "occurredAt": { "type": "string", "format": "date-time" },
    "transcriptId": { "type": ["string", "null"], "minLength": 1, "maxLength": 200 },
    "recordSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code"],
          "properties": { "code": { "type": "string", "minLength": 1, "maxLength": 200 } }
        }
      ]
    }
  }
}
