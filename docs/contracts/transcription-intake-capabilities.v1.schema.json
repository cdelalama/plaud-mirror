{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/cdelalama/plaud-mirror/main/docs/contracts/transcription-intake-capabilities.v1.schema.json",
  "title": "Transcription Intake Capabilities v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "provider", "intakeContract", "statusContract", "statusPush", "statusPull"],
  "properties": {
    "schemaVersion": { "const": "transcription.intake-capabilities.v1" },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "version": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "intakeContract": { "const": "transcription.intake.v1" },
    "statusContract": { "const": "transcription.intake-status.v1" },
    "statusPush": { "const": true },
    "statusPull": { "const": true }
  }
}
