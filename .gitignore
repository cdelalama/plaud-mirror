# LLM-DocKit .gitignore

# Claude Code -- ignore user-specific files, track enforcement config
.claude/*
!.claude/settings.json
!.claude/rules/
!.claude/skills/

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment files
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
node_modules/
jspm_packages/
bower_components/

# Python
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/

# Ruby
*.gem
*.rbc
.bundle/
vendor/bundle/

# Go
*.exe
*.test
*.out
go.work

# Rust
target/

# Build outputs
dist/
build/
out/
*.wasm

# Plaud Mirror runtime data
data/
recordings/
.state/
.cache/plaud-mirror/
tmp/downloads/

# Package manager lock files (optional - uncomment if you want to ignore them)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# Gemfile.lock
# Cargo.lock

# OS files
Thumbs.db
.DS_Store
desktop.ini

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Coverage and test reports
coverage/
.nyc_output/
test-results/

# IDE specific
.vscode/settings.json
.idea/workspace.xml
*.sublime-workspace
